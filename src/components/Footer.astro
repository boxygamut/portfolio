---
import { site } from '../data/site';

const { email, github, website } = site.contact;
const year = new Date().getFullYear();

const socials = [
  email && { label: 'Email', href: `mailto:${email}` },
  github && { label: 'GitHub', href: github },
  website && { label: 'Website', href: website },
].filter(Boolean) as { label: string; href: string }[];
---

<footer class="footer">
  <div class="container footer__inner">
    <ul class="footer__links" aria-label="Contact links">
      {
        socials.map((s) => (
          <li>
            <a
              href={s.href}
              target={s.href.startsWith('mailto:') ? undefined : '_blank'}
              rel="noopener"
            >
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>

    <p class="footer__copy">© {year} {site.name}</p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--surface-2);
    border-top: 1px solid var(--border);
    padding-block: 2.5rem;
    margin-top: var(--space-section);
  }
  .footer::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    opacity: 0.7;
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    list-style: none;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .footer__copy {
    color: var(--text-faint);
    font-size: 0.85rem;
  }
</style>
