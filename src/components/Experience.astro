---
import { site } from '../data/site';
---

<section class="section" id="experience" aria-labelledby="experience-title">
  <div class="container">
    <h2 class="section__title" id="experience-title">Experience</h2>

    <ol class="timeline">
      {
        site.experience.map((job) => (
          <li class="timeline__item">
            <div class="timeline__head">
              <h3 class="timeline__role">
                {job.role} <span class="timeline__company">· {job.company}</span>
              </h3>
              <span class="timeline__dates">{job.dates}</span>
            </div>
            {job.bullets.length > 0 && (
              <ul class="timeline__bullets">
                {job.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    position: relative;
    margin-left: 0.5rem;
  }

  .timeline__item {
    position: relative;
    padding-left: 1.9rem;
    padding-bottom: 2.25rem;
  }
  .timeline__item::after {
    /* the vertical line, starting just below the dot so it doesn't cut through it */
    content: '';
    position: absolute;
    left: 0;
    top: 1.1rem;
    bottom: 0;
    width: 2px;
    z-index: 0;
    background: linear-gradient(var(--border), transparent);
  }
  .timeline__item:last-child {
    padding-bottom: 0;
  }
  .timeline__item:last-child::after {
    display: none;
  }

  .timeline__item::before {
    /* the dot */
    content: '';
    position: absolute;
    left: -4.5px;
    top: 0.4rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--bg);
    z-index: 1;
  }

  .timeline__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.25rem 1rem;
    margin-bottom: 0.65rem;
  }

  .timeline__role {
    font-size: 1.12rem;
    font-weight: 700;
  }
  .timeline__company {
    color: var(--text-muted);
    font-weight: 500;
  }

  .timeline__dates {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-faint);
    white-space: nowrap;
  }

  .timeline__bullets {
    list-style: none;
    display: grid;
    gap: 0.45rem;
    max-width: 36rem;
  }
  .timeline__bullets li {
    color: var(--text-muted);
    position: relative;
    padding-left: 1.2rem;
  }
  .timeline__bullets li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
</style>
